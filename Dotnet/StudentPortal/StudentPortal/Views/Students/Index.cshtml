@model IEnumerable<StudentPortal.Models.Student>

@{
    ViewData["Title"] = "Search and View Students";
}

<div class="row align-items-center mb-4">
    <div class="col-md-6">
        <h1 class="h3 mb-0 text-gray-800">Students Directory</h1>
    </div>
    <div class="col-md-6 text-md-end mt-3 mt-md-0">
        <a asp-action="Create" class="btn btn-primary shadow-sm"><i class="bi bi-plus-circle"></i> Create New</a>
    </div>
</div>

<div class="card shadow mb-4">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-6 col-lg-4">
                <form asp-action="Index" method="get">
                    <div class="input-group">
                        <input type="text" name="SearchString" value="@ViewData["CurrentFilter"]" class="form-control search-input" placeholder="Search by name or email..." />
                        <div class="input-group-append">
                            <button type="submit" class="btn btn-primary search-btn" type="button">Search</button>
                        </div>
                        @if (!String.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                        {
                            <div class="input-group-append ms-2">
                                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                            </div>
                        }
                    </div>
                </form>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.FullName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Phone)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.JoinDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CreatedAt)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.FullName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Phone)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.JoinDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CreatedAt)
            </td>
            <td>
                <div class="table-actions">
                    <a asp-action="Edit" asp-route-id="@item.StudentId" class="text-primary">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.StudentId" class="text-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.StudentId" class="text-danger">Delete</a>
                </div>
            </td>
        </tr>
}
    </tbody>
</table>
        </div>
    </div>
</div>
