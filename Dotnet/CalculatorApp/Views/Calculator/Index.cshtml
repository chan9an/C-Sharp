@model CalculatorApp.Models.CalculatorModel

<!DOCTYPE html>
<html>
<head>
    <title>Calculator</title>
    <style>
        body { font-family: Arial; max-width: 400px; margin: 50px auto; padding: 20px; }
        .form-group { margin-bottom: 15px; }
        label { display: block; margin-bottom: 5px; }
        input { width: 100%; padding: 8px; box-sizing: border-box; }
        button { padding: 10px 20px; margin-right: 10px; cursor: pointer; }
        .result { margin-top: 20px; padding: 15px; background: #f0f0f0; border-radius: 5px; }
    </style>
</head>
<body>
    <h1>Simple Calculator</h1>
    
    <form asp-action="Calculate" method="post">
        <div class="form-group">
            <label>Number 1:</label>
            <input asp-for="Number1" type="number" required />
        </div>
        <div class="form-group">
            <label>Number 2:</label>
            <input asp-for="Number2" type="number" required />
        </div>
        <button type="submit" name="operation" value="add">Add</button>
        <button type="submit" name="operation" value="multiply">Multiply</button>
    </form>

    @if (Model.Result.HasValue)
    {
        <div class="result">
            <strong>@Model.Operation Result:</strong> @Model.Result
        </div>
    }
</body>
</html>
